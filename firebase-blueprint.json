{
  "entities": {
    "HomeData": {
      "title": "HomeData",
      "description": "Stores home page categories and trending links",
      "type": "object",
      "properties": {
        "categories": { "type": "array" },
        "trendingLinks": { "type": "array" },
        "lastUpdated": { "type": "number" }
      }
    },
    "JobPost": {
      "title": "JobPost",
      "description": "Stores individual job posts with details",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "layoutChanged": { "type": "boolean" },
        "lastUpdated": { "type": "number" }
      }
    }
  },
  "firestore": {
    "/home_data/{documentId}": {
      "schema": { "$ref": "#/entities/HomeData" },
      "description": "Home page scraped data"
    },
    "/jobs/{jobId}": {
      "schema": { "$ref": "#/entities/JobPost" },
      "description": "Job posts scraped data"
    }
  }
}
