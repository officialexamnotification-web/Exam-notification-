# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=""

# Firebase Cloud Messaging (Web Push)
# Generate this VAPID key in Firebase Console -> Project Settings -> Cloud Messaging -> Web Push certificates
VITE_VAPID_KEY="BE0NRHzBCW5s6TvRALY-jR8WwH8mCrXGZRndEn6QpCpiB_L0GyIQw27Xx3BPqXNFi2xfqXZEDtBj3qFGyxyYarE"

# Required for Firebase Admin to send FCM push notifications.
# Place the path to your Service Account JSON file, or the stringified JSON here depending on your env setup.
# IMPORTANT: Add your Firebase Service Account JSON here in .env file (not in .env.example)
GOOGLE_APPLICATION_CREDENTIALS=

# If you are using your OWN Firebase project for notifications (because you provided GOOGLE_APPLICATION_CREDENTIALS),
# you MUST also provide your Firebase Client configuration here so the frontend can register tokens to your project.
# You can find these in Firebase Console -> Project Settings -> General -> Your apps -> SDK setup and configuration.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_AUTH_DOMAIN=

# Admin panel authentication key
ADMIN_SECRET_KEY="GovExam@Admin2026!"
GROQ_API_KEY=

# Web3Forms API Key for secure Contact Us form submission
WEB3FORMS_ACCESS_KEY=
